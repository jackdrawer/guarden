# Guarden Environment Configuration Template
#
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control!

# ============================================
# RevenueCat API Keys
# ============================================
# Get your keys from: https://app.revenuecat.com/
#
# Usage: Pass via --dart-define when running/building
# Example: flutter run --dart-define=RC_GOOGLE_API_KEY=your_key_here

RC_GOOGLE_API_KEY=your_revenuecat_google_api_key_here
RC_APPLE_API_KEY=your_revenuecat_apple_api_key_here

# ============================================
# Sentry Configuration
# ============================================
# Crash reporting for production monitoring
# Get your DSN from: https://sentry.io → Create Project → Settings → Client Keys
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ============================================
# Firebase Configuration
# ============================================
# User behavior analytics and performance monitoring
# Get your App IDs from: https://console.firebase.google.com → Project Settings
FIREBASE_APP_ID_ANDROID=1:1234567890:android:abcdef1234567890
FIREBASE_APP_ID_IOS=1:1234567890:ios:abcdef1234567890

# NOTE: Copy to .env and replace with actual values from dashboards

# ============================================
# Build Commands
# ============================================
#
# Development (with API keys):
# flutter run \
#   --dart-define=RC_GOOGLE_API_KEY=$RC_GOOGLE_API_KEY \
#   --dart-define=RC_APPLE_API_KEY=$RC_APPLE_API_KEY
#
# Release build (Android):
# flutter build apk --release \
#   --dart-define=RC_GOOGLE_API_KEY=$RC_GOOGLE_API_KEY
#
# Release build (iOS):
# flutter build ipa --release \
#   --dart-define=RC_APPLE_API_KEY=$RC_APPLE_API_KEY
